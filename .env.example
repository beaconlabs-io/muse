# Project environment
NEXT_PUBLIC_ENV="development"

# This is used to upload contents to IPFS
PINATA_JWT="PINATA_JWT_HERE"

# WalletConnect Project ID - Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="PROJECT_ID_HERE"

# API key of Gemini(required)
GOOGLE_GENERATIVE_AI_API_KEY="API_KEY_HERE"

# The Model of Agent
MODEL="google/gemini-2.5-pro"

# The Model of Keyword Extraction Agent
FLASH_MODEL="google/gemini-2.5-flash"

# API key for bot endpoints (Telegram bot, etc.)
# When set, POST /api/compact and /api/evidence/search require x-api-key header
# When unset, these endpoints are open (suitable for local development)
BOT_API_KEY=""

# External Academic Paper Search (Semantic Scholar)
# Set to "true" to enable external academic paper search. Defaults to disabled.
NEXT_PUBLIC_EXTERNAL_SEARCH_ENABLED=""
# Semantic Scholar API key (optional, improves rate limits)
SEMANTIC_SCHOLAR_API_KEY=""

# ===== Mastra Observability =====
# Storage URL for trace persistence (default: file:./mastra.db)
# For Turso: libsql://your-db.turso.io
MASTRA_STORAGE_URL="file:./mastra.db"
